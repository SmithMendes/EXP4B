<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Shake It Up — Random Cocktail Recipes</title>
  <meta name="description" content="Discover random cocktail recipes with images, ingredients, and instructions. Powered by TheCocktailDB." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <!-- Ambient background -->
  <div class="bg-gradient"></div>
  <div class="bg-noise"></div>

  <!-- Header -->
  <header id="site-header">
    <div class="header-inner">
      <a href="/" class="logo" aria-label="Go back to home">
        <svg class="logo-icon" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M8 2L16 2" />
          <path d="M7.5 2L9.5 12H14.5L16.5 2" />
          <path d="M9.5 12L8 22H16L14.5 12" />
          <path d="M6 22H18" />
          <circle cx="12" cy="7" r="1" fill="currentColor" stroke="none" />
        </svg>
        <h1>Shake It Up</h1>
      </a>
      <p class="tagline">Your next favourite drink is one click away</p>
    </div>
  </header>

  <!-- Main Content -->
  <main id="main-content">

    <% if (error) { %>
      <!-- Error -->
      <section class="glass-card hero-section">
        <p class="error-text"><%= error %></p>
        <a href="/" class="btn-primary">
          <svg class="btn-svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          <span>Back to Home</span>
        </a>
      </section>
    <% } else if (!drink) { %>
      <!-- Landing / Hero -->
      <section class="glass-card hero-section">
        <div class="hero-icon">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="url(#grad1)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <defs>
              <linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" style="stop-color:#c084fc" />
                <stop offset="100%" style="stop-color:#f472b6" />
              </linearGradient>
            </defs>
            <path d="M8 2L16 2" />
            <path d="M7 2L9.5 13H14.5L17 2" />
            <path d="M9.5 13C9.5 13 8.5 18 9 22H15C15.5 18 14.5 13 14.5 13" />
            <path d="M7 22H17" />
          </svg>
        </div>
        <h2>Feeling adventurous?</h2>
        <p>Let us pick a cocktail for you — complete with ingredients, measures, and step-by-step instructions.</p>
        <a href="/random" class="btn-primary">
          <svg class="btn-svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="3" />
            <circle cx="8" cy="8" r="1.2" fill="currentColor" stroke="none" />
            <circle cx="16" cy="8" r="1.2" fill="currentColor" stroke="none" />
            <circle cx="8" cy="16" r="1.2" fill="currentColor" stroke="none" />
            <circle cx="16" cy="16" r="1.2" fill="currentColor" stroke="none" />
            <circle cx="12" cy="12" r="1.2" fill="currentColor" stroke="none" />
          </svg>
          <span>Surprise Me</span>
        </a>
      </section>
    <% } else { %>
      <!-- Cocktail Card -->
      <section class="glass-card cocktail-card">
        <!-- Image -->
        <div class="cocktail-image-wrap">
          <img src="<%= drink.strDrinkThumb %>" alt="<%= drink.strDrink %>" />
          <span class="badge"><%= drink.strAlcoholic || 'Unknown' %></span>
        </div>

        <!-- Details -->
        <div class="cocktail-details">
          <h2 class="cocktail-name"><%= drink.strDrink %></h2>

          <div class="meta-row">
            <span class="chip">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              <span class="chip-label"><%= drink.strCategory || 'Uncategorized' %></span>
            </span>
            <span class="chip chip-outline">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2h8l-1 9H9L8 2z"/><path d="M12 11v8"/><path d="M8 22h8"/></svg>
              <span class="chip-label"><%= drink.strGlass || 'Any glass' %></span>
            </span>
          </div>

          <!-- Ingredients -->
          <div class="section-block">
            <h3>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
              Ingredients
            </h3>
            <ul class="ingredients-list">
              <% ingredients.forEach(function(item) { %>
                <li>
                  <% if (item.measure) { %>
                    <span class="measure"><%= item.measure %></span>
                  <% } %>
                  <%= item.name %>
                </li>
              <% }); %>
            </ul>
          </div>

          <!-- Instructions -->
          <div class="section-block">
            <h3>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
              Instructions
            </h3>
            <p class="instructions-text"><%= drink.strInstructions || 'No instructions available.' %></p>
          </div>

          <!-- Action buttons -->
          <div class="card-actions">
            <a href="/random" class="btn-primary btn-secondary">
              <svg class="btn-svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="23 4 23 10 17 10" />
                <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10" />
              </svg>
              <span>Another Round</span>
            </a>
            <a href="/" class="btn-ghost">
              <svg class="btn-svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                <polyline points="9 22 9 12 15 12 15 22"/>
              </svg>
              <span>Back to Home</span>
            </a>
          </div>
        </div>
      </section>
    <% } %>

  </main>

  <!-- Footer -->
  <footer id="site-footer">
    <p>Powered by <a href="https://www.thecocktaildb.com/" target="_blank" rel="noopener">TheCocktailDB</a>  &middot;  Drink Responsibly</p>
  </footer>
</body>
</html>
